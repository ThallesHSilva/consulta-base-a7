# URL publica do Consulta Base, sem barra no final.
PUBLIC_BASE_URL=https://consulta.seu-dominio.com.br
SESSION_COOKIE_SECURE=1
MAX_UPLOAD_BYTES=314572800

# Primeiro administrador, usado somente quando o banco de autenticacao ainda nao existe.
ADMIN_NAME=Nome do Administrador
ADMIN_EMAIL=admin@seu-dominio.com.br
ADMIN_PASSWORD=troque-esta-senha

# Zoho Mail para conta corporativa com dominio proprio.
SMTP_HOST=smtppro.zoho.com
SMTP_PORT=587
SMTP_USER=seu-email@seu-dominio.com.br
SMTP_PASSWORD=senha-especifica-do-aplicativo-zoho
SMTP_FROM=seu-email@seu-dominio.com.br
SMTP_TLS=1
